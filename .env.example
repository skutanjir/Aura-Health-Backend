# ========================
# SERVER
# ========================
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================
# DATABASE (Supabase PostgreSQL)
# ========================
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ========================
# JWT
# ========================
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ========================
# REDIS
# ========================
REDIS_URL=redis://localhost:6379
# Atau gunakan Upstash:
# REDIS_URL=rediss://:[password]@[host]:6380

# ========================
# SUPABASE STORAGE
# ========================
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_POSTS=posts

# ========================
# AI PROVIDER
# ========================
# Options: auto | openrouter | ollama | huggingface | mock
AI_PROVIDER=auto

AI_OPENROUTER_KEY=sk-or-v1-...
AI_OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

AI_OLLAMA_URL=http://localhost:11434
AI_OLLAMA_MODEL=llama3

AI_HF_KEY=hf_...
AI_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ========================
# OTP CONFIG
# ========================
OTP_EXPIRES_SECONDS=300
