# ========================
# SERVER
# ========================
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================
# DATABASE (Supabase PostgreSQL)
# ========================
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ========================
# JWT
# ========================
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ========================
# REDIS
# ========================
REDIS_URL=redis://localhost:6379
# Atau gunakan Upstash:
# REDIS_URL=rediss://:[password]@[host]:6380

# ========================
# SUPABASE STORAGE
# ========================
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_POSTS=posts

# ========================
# AI PROVIDER
# ========================
# Options: auto | openrouter | ollama | huggingface | mock
AI_PROVIDER=auto

AI_OPENROUTER_KEY=sk-or-v1-...
AI_OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

AI_GROQ_KEY=
AI_GROQ_MODEL=llama3-8b-8192

AI_HF_KEY=hf_...
AI_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

AI_GEMINI_MODEL=gemini-flash-lite-latest
AI_GEMINI_KEY_1=AIzaSy...
AI_GEMINI_KEY_2=
AI_GEMINI_KEY_3=
AI_GEMINI_KEY_4=
AI_GEMINI_KEY_5=
AI_GEMINI_KEY_6=
AI_GEMINI_KEY_7=
AI_GEMINI_KEY_8=
AI_GEMINI_KEY_9=
AI_GEMINI_KEY_10=

# ========================
# OTP CONFIG
# ========================
OTP_EXPIRES_SECONDS=300
